{
  "name": "ielts-local-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @ielts/server --filter @ielts/web dev",
    "build": "pnpm -r --if-present build",
    "desktop:check": "node scripts/desktop-check.mjs",
    "desktop:build:mac": "pnpm --filter @ielts/web desktop:build:mac",
    "desktop:build:win": "pnpm --filter @ielts/web desktop:build:win",
    "v1:check": "node scripts/v1-readiness-check.mjs",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @ielts/web test:e2e",
    "db:migrate": "pnpm --filter @ielts/server db:migrate",
    "db:seed": "pnpm --filter @ielts/server db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
