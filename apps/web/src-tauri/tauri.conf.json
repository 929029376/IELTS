{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IELTS Local Practice",
  "version": "0.0.0",
  "identifier": "local.ielts.practice",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IELTS Local Practice",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Local IELTS listening and reading practice.",
    "longDescription": "A personal local IELTS listening and reading practice app with mock exams, intensive study, analytics, sync, and backups."
  }
}
